# Copy to `.env.local` for local dev. In Vercel: Project → Settings → Environment Variables.
# Keep secrets server-side only. `NEXT_PUBLIC_*` values are shipped to clients.

# Required: used by /api/generate and /api/import extraction.
OPENAI_API_KEY=

# Optional: defaults to gpt-4.1-mini where set in route logic.
OPENAI_MODEL=gpt-4.1-mini

# Optional: YouTube extraction quality is better when set.
YOUTUBE_API_KEY=

# Optional: set "true" to bypass LLM provider in local debugging flows.
PROTEINIFY_USE_MOCK=false

# Optional public API override for web/native clients.
# Example: https://foodzap-khaki.vercel.app
NEXT_PUBLIC_API_BASE_URL=

# Optional comma-separated fallback API origins (ordered, no trailing slash).
# Example: https://foodzap.vercel.app,https://proteinify1.vercel.app
NEXT_PUBLIC_API_FALLBACK_URLS=

# Normally set by Next/Vercel at build time; leave blank locally.
NEXT_PUBLIC_FOODZAP_BUILD_ID=

# Optional: Microsoft Clarity session recording project ID.
# Set after creating the project at clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Build mode switch:
# - Leave unset for serverful Next deploys (must expose /api/*)
# - Set true only for Android static bundle sync via npm run build:android
# FOODZAP_STATIC_EXPORT=true
