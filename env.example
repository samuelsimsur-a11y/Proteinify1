# Real AI (OpenAI). Omit or set PROTEINIFY_USE_MOCK to use local mock.
OPENAI_API_KEY=

# Optional. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional. Only openai is implemented.
PROTEINIFY_AI_PROVIDER=openai

# Set to "true" to skip OpenAI and use the local mock generator (no API key).
# In development, mock is used automatically if OPENAI_API_KEY is unset.
PROTEINIFY_USE_MOCK=false

# YouTube Data API v3 key used by /api/import for YouTube recipe description extraction.
YOUTUBE_API_KEY=

# Optional for Android/static export clients. Point to your deployed API origin,
# e.g. https://foodzap.vercel.app (no trailing slash). Leave unset on a normal Vercel
# Next deploy so the browser uses same-origin /api/*. If set to a static-only host,
# /api/generate will 404 unless that host runs the API routes.
NEXT_PUBLIC_API_BASE_URL=

# Set only for local Capacitor `webDir` sync: `FOODZAP_STATIC_EXPORT=true npm run build`
# produces `out/` with no API routes. Vercel builds must leave this unset so /api/* deploys.
# FOODZAP_STATIC_EXPORT=true
