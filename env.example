# Real AI (OpenAI). Omit or set PROTEINIFY_USE_MOCK to use local mock.
OPENAI_API_KEY=

# Optional. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional. Only openai is implemented.
PROTEINIFY_AI_PROVIDER=openai

# Set to "true" to skip OpenAI and use the local mock generator (no API key).
# In development, mock is used automatically if OPENAI_API_KEY is unset.
PROTEINIFY_USE_MOCK=false

# YouTube Data API v3 key used by /api/import for YouTube recipe description extraction.
YOUTUBE_API_KEY=
