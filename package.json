{
  "name": "proteinify",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --webpack --port 3000",
    "dev:auto": "PORT=${PORT:-3000}; while lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; do PORT=$((PORT+1)); done; echo \"Starting dev server on port $PORT\"; next dev --webpack --port $PORT",
    "dev:3001": "next dev --webpack --port 3001",
    "dev:ipv4": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "dev:turbopack": "next dev --turbopack --port 3000",
    "dev:local": "next dev --webpack --port 3000",
    "build": "next build",
    "build:android": "FOODZAP_STATIC_EXPORT=true next build && npx cap sync android",
    "android": "npx cap run android",
    "android:open": "npx cap open android",
    "android:restart": "npm run build:android && npx cap run android",
    "start": "next start",
    "start:local": "next start --port 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "next": "latest",
    "openai": "^4.77.0",
    "react": "latest",
    "react-dom": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "^4",
    "typescript": "latest"
  }
}
